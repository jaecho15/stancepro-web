# Supabase + Auth email configuration example
# Copy this file to .env.local and fill in your values.

RESEND_API_KEY=
NEXT_PUBLIC_SITE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Web app public Supabase keys (required on Vercel for /internal/* routes)
NEXT_PUBLIC_SUPABASE_URL=https://ryiitcblrrqvjvxkobpf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Or newer publishable key (preferred):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Internal magic-link redirect (add in Supabase Auth → URL configuration):
# https://stance-pro.com/internal/auth/callback
# Legacy (still forwarded): https://stance-pro.com/brand-review/auth/callback







